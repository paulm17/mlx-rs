# Model matrix config for scripts/run_moe_finishline_matrix.sh
# You can point to either:
# 1) the HF cache model root (models--...); snapshots will be auto-resolved
# 2) a specific snapshots/<hash> directory

# Tier-1 models
QWEN3_MODEL_PATH="/Volumes/Data/Users/paul/.cache/huggingface/hub/models--Qwen--Qwen3-1.7B-MLX-4bit"
LLAMA3_MODEL_PATH="/Volumes/Data/Users/paul/.cache/huggingface/hub/models--mlx-community--Llama-3.2-1B-Instruct-4bit"
QWEN15_MOE_A2P7B_MODEL_PATH="/Volumes/Data/Users/paul/.cache/huggingface/hub/models--mlx-community--Qwen1.5-MoE-A2.7B-4bit"

# Model-specific gate strictness
QWEN3_MIN_GREEDY_PREFIX=8
LLAMA3_MIN_GREEDY_PREFIX=3
QWEN15_MOE_A2P7B_MIN_GREEDY_PREFIX=8

# Optional extra models:
# format: "name=/abs/path@min_prefix;name2=/abs/path2@min_prefix"
# Examples using your available models:
# EXTRA_MODELS="qwen15_moe_a2p7b=/Volumes/Data/Users/paul/.cache/huggingface/hub/models--mlx-community--Qwen1.5-MoE-A2.7B-4bit@8;mixtral_8x7b=/Volumes/Data/Users/paul/.cache/huggingface/hub/models--mlx-community--Mixtral-8x7B-v0.1-hf-4bit-mlx@8;lfm2_24b_a2b=/Volumes/Data/Users/paul/.cache/huggingface/hub/models--LiquidAI--LFM2-24B-A2B-MLX-4bit@3"
EXTRA_MODELS="${EXTRA_MODELS:-qwen15_moe_a2p7b_4bit=${QWEN15_MOE_A2P7B_MODEL_PATH}@${QWEN15_MOE_A2P7B_MIN_GREEDY_PREFIX}}"
